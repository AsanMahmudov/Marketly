@model Marketly.Core.ViewModels.AdMinifiedViewModel

<div class="card h-100 shadow-sm border-0 transition-hover">
    <div class="position-relative">
        <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" style="height: 200px; object-fit: cover;">
        <span class="badge bg-primary position-absolute top-0 start-0 m-2">@Model.Category</span>
    </div>
    <div class="card-body d-flex flex-column">
        <h5 class="card-title text-truncate">@Model.Title</h5>
        <p class="text-success fw-bold mb-1">@Model.Price.ToString("C")</p>
        <p class="text-muted small mb-3">Seller: @Model.SellerName</p>
        <div class="mt-auto">
            <a asp-controller="Ads" asp-action="Details" asp-route-id="@Model.Id"
               class="btn btn-outline-primary btn-sm w-100">View Details</a>
        </div>
    </div>
</div>