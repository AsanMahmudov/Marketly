@model IEnumerable<Marketly.Core.ViewModels.MessageInboxViewModel>

@{
    var firstMsg = Model.FirstOrDefault();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <a asp-action="Inbox" class="btn btn-link mb-3 text-decoration-none p-0">
                <i class="bi bi-arrow-left"></i> Back to Inbox
            </a>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <div class="d-flex align-items-center">
                        <img src="@firstMsg?.AdImageUrl" class="rounded me-3"
                             style="width: 60px; height: 60px; object-fit: cover;" alt="Ad Image">
                        <div>
                            <h6 class="mb-0 fw-bold">@firstMsg?.AdTitle</h6>
                            <small class="text-muted">Chatting about Ad #@firstMsg?.RelatedAdId</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 bg-light" style="height: 450px; overflow-y: auto;">
                    @foreach (var msg in Model)
                    {
                        bool isMe = msg.SenderName == "Me";
                        <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") mb-3">
                            <div class="p-3 rounded shadow-sm @(isMe ? "bg-primary text-white" : "bg-white text-dark")"
                                 style="max-width: 75%; border-radius: 15px !important;">
                                <p class="mb-1">@msg.Content</p>
                                <small class="d-block @(isMe ? "text-white-50" : "text-muted")" style="font-size: 0.7rem;">
                                    @msg.SentDate.ToString("t")
                                </small>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-white p-3">
                    @if (firstMsg != null)
                    {
                        var lastMsg = Model.Last();
                        var recipientId = lastMsg.SenderName == "Me" ? lastMsg.ReceiverId : lastMsg.SenderId;

                        <a asp-action="Create"
                           asp-route-recipientId="@recipientId"
                           asp-route-adId="@lastMsg.RelatedAdId"
                           class="btn btn-primary w-100 py-2">Reply to Message</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>