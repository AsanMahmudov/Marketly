@model IEnumerable<Marketly.Core.ViewModels.MessageInboxViewModel>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <a asp-action="Inbox" class="btn btn-link mb-3 text-decoration-none p-0">
                <i class="bi bi-arrow-left"></i> Back to Inbox
            </a>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Conversation Thread</h5>
                </div>
                <div class="card-body p-4 bg-light" style="max-height: 500px; overflow-y: auto;">
                    @foreach (var msg in Model)
                    {
                        bool isMe = msg.SenderName == "Me";
                        <div class="d-flex @(isMe ? "justify-content-end" : "justify-content-start") mb-3">
                            <div class="p-3 rounded shadow-sm @(isMe ? "bg-primary text-white" : "bg-white text-dark")" style="max-width: 80%;">
                                <p class="mb-1">@msg.Content</p>
                                <small class="d-block text-end @(isMe ? "text-white-50" : "text-muted")" style="font-size: 0.7rem;">
                                    @msg.SentDate.ToString("g")
                                </small>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer bg-white p-3">
                    @{
                        var lastMsg = Model.Last();
                        // If I sent the last message, the recipient is the ReceiverId.
                        // If they sent it, the recipient is the SenderId.
                        var recipientId = lastMsg.SenderName == "Me" ? lastMsg.ReceiverId : lastMsg.SenderId;
                    }
                    <a asp-action="Create"
                       asp-route-recipientId="@recipientId"
                       asp-route-adId="@lastMsg.RelatedAdId"
                       class="btn btn-primary w-100">Reply to Conversation</a>
                </div>
            </div>
        </div>
    </div>
</div>