@model IEnumerable<Marketly.Core.ViewModels.MessageInboxViewModel>

<div class="container py-4">
    <h2 class="mb-4">Messages</h2>
    <div class="list-group shadow-sm">
        @foreach (var message in Model)
        {
            <a asp-action="Details" asp-route-id="@message.Id"
               class="list-group-item list-group-item-action @(message.IsRead ? "" : "bg-light fw-bold") py-3">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@message.SenderName</h5>
                    <small class="text-muted">@message.SentDate.ToShortDateString()</small>
                </div>
                <p class="mb-1 text-truncate">@message.Content</p>
                <small class="text-primary">Related Ad: #@message.RelatedAdId</small>
            </a>
        }
    </div>
</div>