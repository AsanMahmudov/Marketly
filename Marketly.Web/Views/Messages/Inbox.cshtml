@model IEnumerable<Marketly.Core.ViewModels.MessageInboxViewModel>

<div class="container py-4">
    <h2 class="mb-4">Your Conversations</h2>
    <div class="list-group shadow-sm">
        @foreach (var convo in Model)
        {
            <a asp-action="Details" asp-route-id="@convo.Id"
               class="list-group-item list-group-item-action py-3 border-start border-4 @(convo.SenderName == "Me" ? "border-light" : "border-primary")">
                <div class="d-flex w-100 justify-content-between">
                    <h6 class="mb-1 fw-bold">@(convo.SenderName == "Me" ? "To: User" : convo.SenderName)</h6>
                    <small class="text-muted">@convo.SentDate.ToShortDateString()</small>
                </div>
                <p class="mb-1 text-truncate text-muted">@convo.Content</p>
            </a>
        }
    </div>
</div>