@using System.Security.Claims
@model Marketly.Core.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = $"{Model.Username}'s Profile";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isOwner = currentUserId == Model.Id;
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                        @Model.Username[0].ToString().ToUpper()
                    </div>
                    <h4 class="mb-0">@Model.Username</h4>
                    <p class="text-muted small">Member since @Model.JoinDate.ToString("MMMM yyyy")</p>
                    <hr />
                    <div class="text-start">
                        <p><strong>Email:</strong> @Model.Email</p>
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <p><strong>Phone:</strong> @Model.PhoneNumber</p>
                        }
                    </div>

                    @if (isOwner)
                    {
                        <div class="d-grid gap-2 mt-3">
                            <a asp-controller="Ads" asp-action="MyAds" class="btn btn-primary">
                                <i class="bi bi-gear"></i> Manage My Ads
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3>@(isOwner ? "My Listings" : $"{Model.Username}'s Listings")</h3>
                <span class="badge bg-secondary">@Model.UserAds.Count() Items</span>
            </div>

            @if (!Model.UserAds.Any())
            {
                <div class="alert alert-light border text-center py-5">
                    <p class="text-muted mb-0">This user hasn't posted any advertisements yet.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 g-4">
                    @foreach (var ad in Model.UserAds)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0">
                                <img src="@ad.ImageUrl" class="card-img-top" style="height: 180px; object-fit: cover;" alt="@ad.Title">
                                <div class="card-body">
                                    <h6 class="card-title text-truncate">@ad.Title</h6>
                                    <p class="text-primary fw-bold mb-2">$@ad.Price</p>
                                    <a asp-controller="Ads" asp-action="Details" asp-route-id="@ad.Id" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>