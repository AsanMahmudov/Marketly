@model Marketly.Core.ViewModels.UserProfileViewModel

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-md-4 text-center border-end">
            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px; font-size: 2rem;">
                @Model.Username[0].ToString().ToUpper()
            </div>
            <h3>@Model.Username</h3>
            <p class="text-muted">Member since @Model.JoinDate.ToString("MMMM yyyy")</p>
            <ul class="list-unstyled text-start px-4 mt-4">
                <li><i class="bi bi-geo-alt me-2"></i><strong>Location:</strong> @(Model.City ?? "Not specified")</li>
                <li><i class="bi bi-envelope me-2"></i><strong>Email:</strong> @Model.Email</li>
            </ul>
        </div>
        <div class="col-md-8 ps-md-5">
            <h4 class="mb-4">Active Listings (@Model.UserAds.Count())</h4>
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var ad in Model.UserAds)
                {
                    <div class="col">
                        <partial name="_AdCardPartial" model="ad" />
                    </div>
                }
            </div>
        </div>
    </div>
</div>