@using Marketly.Core.ViewModels
@model IEnumerable<AdMinifiedViewModel>

<div class="hero-section text-center py-5">
    <h1>Welcome to Marketly</h1>
    <p>Find the best deals or start selling today!</p>
</div>

<h2 class="mb-4">Latest Listings</h2>
<div class="row">
    @foreach (var ad in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <img src="@ad.ImageUrl" class="card-img-top" alt="@ad.Title">
                <div class="card-body">
                    <h5 class="card-title">@ad.Title</h5>
                    <p class="text-primary fw-bold">$@ad.Price</p>
                    <a asp-controller="Ads" asp-action="Details" asp-route-id="@ad.Id" class="btn btn-outline-primary">View Details</a>
                </div>
            </div>
        </div>
    }
</div>