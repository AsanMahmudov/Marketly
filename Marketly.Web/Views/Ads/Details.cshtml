@model Marketly.Core.ViewModels.AdDetailsViewModel
@using System.Security.Claims

@{
    ViewBag.Title = Model.Title;
    // Check if the current user is the owner using the SellerId from the model
    bool isOwner = Model.SellerId == User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-7">
            @if (Model.ImageUrls != null && Model.ImageUrls.Any())
            {
                <div id="adCarousel" class="carousel slide shadow" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @{
                            int i = 0;
                        }
                        @foreach (var url in Model.ImageUrls)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@url" class="d-block w-100 rounded" style="max-height: 500px; object-fit: cover;" alt="Listing Image">
                            </div>
                            i++;
                        }
                    </div>
                    @if (Model.ImageUrls.Count() > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#adCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#adCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }
                </div>
            }
            else
            {
                <img src="/img/no-image.png" class="img-fluid rounded shadow" alt="No image">
            }
        </div>

        <div class="col-md-5">
            <span class="badge bg-secondary mb-2">@Model.Category</span>
            <h1 class="fw-bold">@Model.Title</h1>

            <h3 class="text-success">$@Model.Price.ToString("F2")</h3>
            <p class="text-muted">Listed on @Model.CreatedDate.ToShortDateString()</p>

            <hr />
            <h5>Description</h5>
            <p>@Model.Description</p>

            <div class="card bg-light mt-4">
                <div class="card-body">
                    <p class="mb-1"><strong>Seller:</strong> @Model.SellerName</p>
                    <p class="mb-3"><strong>Status:</strong> @(Model.IsAvailable ? "Available" : "Sold")</p>

                    <div class="d-grid gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (isOwner)
                            {
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Listing</a>
                            }
                            else
                            {
                                <a asp-controller="Messages" asp-action="Create"
                                   asp-route-recipientId="@Model.SellerId"
                                   asp-route-adId="@Model.Id"
                                   class="btn btn-primary">Message Seller</a>

                                <form asp-action="AddToWatchlist" asp-route-id="@Model.Id" method="post">
                                    <button type="submit" class="btn btn-outline-danger">Add to Watchlist</button>
                                </form>
                            }
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary">Login to Contact Seller</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>