@model Marketly.Core.ViewModels.AdDetailsViewModel
@using System.Security.Claims

@{
    ViewBag.Title = Model.Title;
    // Check if the current user is the owner using the SellerId from the model
    bool isOwner = Model.SellerId == User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-7">
            @if (Model.ImageUrls != null && Model.ImageUrls.Any())
            {
                <div id="adCarousel" class="carousel slide shadow" data-bs-ride=\"carousel\">
                    <div class="carousel-inner">
                        @{
                            int i = 0;
                        }
                        @foreach (var url in Model.ImageUrls)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@url" class="d-block w-100 rounded" style="max-height: 500px; object-fit: cover;" alt="Listing Image">
                            </div>
                            i++;
                        }
                    </div>
                    @if (Model.ImageUrls.Count() > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#adCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#adCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }
                </div>
            }

            <div class="mt-4">
                <h1 class="fw-bold">@Model.Title</h1>
                <span class="badge bg-info text-dark mb-3">@Model.Category</span>
                <h3 class="text-primary mb-3">$@Model.Price</h3>
                <hr />
                <h5>Description</h5>
                <p class="text-muted" style="white-space: pre-line;">@Model.Description</p>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Seller Information</h5>
                    <hr />

                    <p class="mb-1">
                        <strong>Seller:</strong>
                        <a asp-controller="Users" asp-action="Profile" asp-route-id="@Model.SellerId" class="text-decoration-none">
                            <i class="bi bi-person-circle me-1"></i> @Model.SellerName
                        </a>
                    </p>

                    <p class="text-muted small">Posted on @Model.CreatedDate.ToString("f")</p>

                    <div class="d-grid gap-2 mt-4">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (isOwner)
                            {
                                <a asp-controller="Ads" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                    <i class="bi bi-pencil-square"></i> Edit Listing
                                </a>
                                <a asp-controller="Ads" asp-action="MyAds" class="btn btn-outline-secondary">Back to My Ads</a>
                            }
                            else
                            {
                                <a asp-controller="Messages" asp-action="Create"
                                   asp-route-recipientId="@Model.SellerId"
                                   asp-route-adId="@Model.Id"
                                   class="btn btn-primary">
                                    <i class="bi bi-envelope"></i> Message Seller
                                </a>

                                <form asp-controller="Users" asp-action="AddToWatchlist" asp-route-id="@Model.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger w-100">
                                        <i class="bi bi-heart"></i> Add to Watchlist
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary">
                                Login to Contact Seller
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a asp-controller="Ads" asp-action="All" class="btn btn-link text-decoration-none">
                    <i class="bi bi-arrow-left"></i> Back to all listings
                </a>
            </div>
        </div>
    </div>
</div>