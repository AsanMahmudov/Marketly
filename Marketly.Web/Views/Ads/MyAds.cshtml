@model IEnumerable<Marketly.Core.ViewModels.AdMinifiedViewModel>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Active Listings</h2>
        <a asp-action="Create" class="btn btn-success">Post New Ad</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded">
            <p class="lead text-muted">You haven't posted any ads yet.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var ad in Model)
            {
                <div class="col">
                    <div class="card shadow-sm border-0 h-100">
                        <img src="@ad.ImageUrl" class="card-img-top" style="height: 180px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title text-truncate">@ad.Title</h5>
                            <p class="text-success fw-bold">@ad.Price.ToString("C")</p>
                            <div class="d-grid gap-2">
                                <a asp-action="Edit" asp-route-id="@ad.Id" class="btn btn-outline-warning btn-sm">Edit Listing</a>
                                <form asp-action="Delete" asp-route-id="@ad.Id" method="post" onsubmit="return confirm('Are you sure?')">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">Remove</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>