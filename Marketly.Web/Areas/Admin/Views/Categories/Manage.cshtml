@model IEnumerable<Marketly.Core.ViewModels.CategoryAdminViewModel>

@{
    ViewData["Title"] = "Manage Categories";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Administrative Oversight</h2>
            <p class="text-muted mb-0">Manage system categories and monitor listing distribution.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Add New Category
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-folder-x display-4 d-block mb-2"></i>
                                No categories found in the system.
                            </td>
                        </tr>
                    }
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>@cat.Id</td>
                            <td>@cat.Name</td>
                            <td><span class="badge bg-info">@cat.AdCount</span></td>
                            <td class="text-end">

                                @* The "Data" attributes store the info for the JS to grab *@
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        onclick="openDeleteModal('@cat.Id', '@cat.Name', @cat.AdCount)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }

                    @* Inject the single modal partial at the bottom of the page *@
                    <partial name="_DeleteCategoryModalPartial" />
                    <script>
                        function openDeleteModal(id, name, adCount) {
                            const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
                            const alert = document.getElementById('deleteErrorAlert');
                            const btn = document.getElementById('confirmDeleteBtn');
                            const msg = document.getElementById('deleteMessage');

                            // Set the ID in the hidden form input
                            document.getElementById('deleteCategoryId').value = id;

                            if (adCount > 0) {
                                // Logic matches CategoryService.DeleteAsync safety check
                                alert.classList.remove('d-none');
                                btn.classList.add('d-none');
                                msg.innerHTML = `Category <strong>${name}</strong> is locked.`;
                            } else {
                                alert.classList.add('d-none');
                                btn.classList.remove('d-none');
                                msg.innerHTML = `Are you sure you want to delete <strong>${name}</strong>?`;
                            }

                            modal.show();
                        }
                    </script>
                </tbody>
            </table>
        </div>
    </div>
</div>